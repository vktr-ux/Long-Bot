[Unit]
Description=Long-Bot paper dashboard
After=network-online.target long-bot-paper.service
Wants=network-online.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/opt/Long-Bot
EnvironmentFile=/opt/Long-Bot/.env
ExecStart=/opt/Long-Bot/.venv/bin/python -m app.web.server --config config.paper.yaml --host 127.0.0.1 --port 8008
Restart=always
RestartSec=10
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
